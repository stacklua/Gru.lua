local function safeStr(v)    return tostring(v or "") end
local function safeNum(v, d) return tonumber(v) or d or 0 end
local function safeTable(t)  return type(t) == "table" and t or {} end

local function splitCommaReplies(str)
	local result = {}
	for part in tostring(str or ""):gmatch("[^,]+") do
		local s = part:match("^%s*(.-)%s*$")
		if s and s ~= "" then table.insert(result, s) end
	end
	return result
end

local function joinCommaReplies(t)
	local tbl = safeTable(t)
	return table.concat(tbl, ",")
end

local function fireOutfitRemote(withArg)
	pcall(function()
		local rf = ReplicatedStorage:FindFirstChild("Remotes")
		if rf then
			local r = rf:FindFirstChild("2DAysGYShnLrkmAhx1JIi3GE3A6QZ3VGKTjmJ2iSxD0=")
			if r then
				if r:IsA("RemoteFunction") then r:InvokeServer(withArg)
				elseif r:IsA("RemoteEvent") then r:FireServer(withArg) end
			end
		end
	end)
end

