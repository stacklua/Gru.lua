task.spawn(function()
	postStatusEmbed()
	while task.wait(30) do updateStatusEmbed() end
end)

-- Auto text update loop
task.spawn(function()
	while task.wait(10) do updateBoothText() end
end)

if getgenv().settings.autoBeg then spamming = task.spawn(begging) end

-- SECTION: Auto Emote Loop
task.spawn(function()
	repeat task.wait() until bclaimed
	if getgenv().settings.autoEmote then task.wait(1); playEmote() end
	while task.wait(1) do
		if getgenv().settings.autoEmote then
			if not emoteTrack or not emoteTrack.IsPlaying then playEmote() end
		else
			if emoteTrack and emoteTrack.IsPlaying then stopEmote() end
		end
	end
end)

-- SECTION: Auto Return to Booth if Drifted
task.spawn(function()
	repeat task.wait() until bclaimed
	task.wait(2)
	while task.wait(0.5) do
		if not bclaimed then continue end
		local bp     = safeNum(getgenv().settings.boothPosition, -6)
		local target = boothCFrameForPosition(bp)
		if not target then continue end
		local hrp = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if not hrp then continue end
		local dist = (hrp.Position - target.Position).Magnitude
		if dist > 4 then
			local t = twn(hrp, TweenInfo.new(math.max(dist / 32, 0.15), Enum.EasingStyle.Linear), { CFrame = target })
			t:Play()
			t.Completed:Wait()
			hrp.CFrame = facingBoothFront(hrp.Position)
		end
	end
end)

-- SECTION: Auto Hop if < 5 Players
task.spawn(function()
	repeat task.wait() until bclaimed
	while task.wait(30) do
		if #Players:GetPlayers() < 5 then
			Fluent:Notify({ Title = "Low Population", Content = "Less than 5 players — hopping", Duration = 3 })
			setHopReason("Low population")
			serverHop()
		end
	end
end)

-- SECTION: Remote Control Polling
task.spawn(function()
	while task.wait(5) do
		local url = safeStr(getgenv().settings.remoteControlUrl)
		if url == "" then continue end
		local ok, res = pcall(function() return httprequest({ Url = url, Method = "GET" }) end)
		if not ok or not res then continue end
		local cmd = tostring(res.Body or ""):match("^%s*(.-)%s*$"):lower()
		if cmd == "" or cmd == "none" then continue end
		if cmd == "hop" then serverHop()
		elseif cmd == "stop" then getgenv().settings.autoBeg = false
		elseif cmd == "status" then task.spawn(postStatusEmbed)
		elseif cmd:sub(1,8) == "settext:" then
			local newText = cmd:sub(9)
			getgenv().settings.customBoothText = newText; saveSettings(); lastBoothFont = ""; updateBoothText()
		end
	end
end)

-- SECTION: Donation Handler
local RaisedC     = newRaisedFormat.Value
local lapdebounce = false

ReplicatedStorage.VFXObjects.CreateVfx.OnClientEvent:Connect(function(...)
	local args = { ... }
	local don  = args[4]
	local user = args[3]
	if user ~= Players.LocalPlayer.Character or args[1] ~= 'GiveCurrency' then return end
	if not don or typeof(don) ~= 'number' then don = 1 end

	local playerWhoDonated
	sgoalR = sgoalR + (newRaisedFormat.Value - RaisedC)
	local raised = don
	extendHopTimer()  -- push hop back 1 minute on donation

	if getgenv().settings.webhookToggle and safeStr(getgenv().settings.webhookBox) ~= "" then
		task.spawn(function()
			playerWhoDonated = fetchNearPlr()
			if playerWhoDonated then pcall(function() webhook(raised, playerWhoDonated.Name, playerWhoDonated.UserId) end)
			else pcall(function() webhook(raised, "Unknown", nil) end) end
		end)
	end

	if getgenv().settings.autoThanks then
		task.spawn(function()
			task.wait(safeNum(getgenv().settings.thanksDelay, 3))
			local msgs = safeTable(getgenv().settings.thanksMessage)
			if #msgs > 0 then chat(msgs[math.random(#msgs)]) end
		end)
	end

	Fluent:Notify({ Title = "Donation!", Content = tostring(raised) .. " R$ received", Duration = 3 })
	task.wait(5); updateBoothText()
end)

updateBoothText()

-- SECTION: Auto-Reclaim
task.spawn(function()
	while task.wait(5) do
		if bclaimed and unclaimed[1] then
			local boothUI = _boothlocation.BoothUI:FindFirstChild("BoothUI" .. tostring(unclaimed[1]))
			if boothUI and not string.find(boothUI.Details.Owner.Text, Players.LocalPlayer.DisplayName) then
				warn("Booth taken, reclaiming...")
				bclaimed = false
				pcall(function() Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[1]) end)
				task.wait(1)
				if string.find(boothUI.Details.Owner.Text, Players.LocalPlayer.DisplayName) then
					bclaimed = true; updateBoothText()
				else setHopReason("Booth reclaim failed"); serverHop() end
			end
		end
	end
end)

-- SECTION: Position Monitoring
task.spawn(function()
	task.wait(5)
	Players.LocalPlayer.CharacterRemoving:Connect(function()
		stopEmote()
	end)
end)

task.spawn(function()
	while task.wait(5) do
		local char = Players.LocalPlayer.Character
		if char and char:FindFirstChildOfClass('Humanoid') and char:FindFirstChildOfClass('Humanoid').RootPart then
			if (char:FindFirstChildOfClass('Humanoid').RootPart.Position - positionX).Magnitude > 1100 then setHopReason("Position drift"); serverHop() end
		end
	end
end)

-- SECTION: Auto Reply
local messagesToResp = {
	Greetings = {'hi','hello','hey','sup','yo','howdy','sup bro','sup dude','hai','hii','hey man','hiya','heyy','hello man','hello dude','hi bro','hi sup','hola','👋','hey hello','sup hi','hi there','hello there','heya','wassup','wsg','wsp'},
}

Players.PlayerChatted:Connect(function(_, player, message)
	local speaker = tostring(player)
	local msg     = string.lower(tostring(message or ""))
	if #msg < 2 then return end
	if string.find(msg,'hop') or string.find(msg,'server') then return end
	task.wait(2.1 + math.random())
	local plrChatted = Players:FindFirstChild(speaker)
	if not plrChatted or plrChatted == Players.LocalPlayer then return end
	if not getgenv().settings.autoNearReply then return end
	if string.find(msg,'donates') or string.find(msg,'spamming') then return end
	if plrChatted:GetAttribute('respcd') then return end
	pcall(function()
		plrChatted:SetAttribute('respcd', true)
		if plrChatted.Character and plrChatted.Character.Humanoid and plrChatted.Character.Humanoid.RootPart then
			local root   = plrChatted.Character.Humanoid.RootPart
			local myChar = Players.LocalPlayer.Character
			local myRoot = myChar and myChar.Humanoid and myChar.Humanoid.RootPart
			if myRoot and (root.Position - myRoot.Position).Magnitude < 18 then
				local function reply(key)
					local t = safeTable(getgenv().settings[key])
					if #t == 0 then return end
					local now = os.time()
					local available = {}
					for _, r in ipairs(t) do
						if not lastReply[r] or (now - lastReply[r]) >= 30 then
							table.insert(available, r)
						end
					end
					if #available == 0 then available = t end
					local chosen = available[math.random(#available)]
					lastReply[chosen] = os.time()
					chat(chosen)
				end
				if table.find(messagesToResp.Greetings, msg) then reply("helloResponce")
				elseif string.find(msg,'bot') then reply("botResponce")
				elseif string.find(msg,'donate') then reply("donateResponce")
				end
			end
		end
		local cd = arCooldowns[speaker] or 15
		arCooldowns[speaker] = math.min(cd * 1.5, 120)
		task.wait(cd)
		arCooldowns[speaker] = math.max((arCooldowns[speaker] or 15) * 0.8, 15)
		plrChatted:SetAttribute('respcd', false)
	end)
end)

-- SECTION: Blacklist + Auto-Destroy Other Characters
local function setupCharacterDestroy(player)
	if player == Players.LocalPlayer then return end
	if player.Character then
		pcall(function() player.Character:Destroy() end)
	end
	player.CharacterAdded:Connect(function(char)
		task.wait(0.1)
		pcall(function() char:Destroy() end)
	end)
end

Players.PlayerAdded:Connect(function(player)
	checkBlacklist(player)
	setupCharacterDestroy(player)
end)
for _, player in next, Players:GetPlayers() do
	checkBlacklist(player)
	setupCharacterDestroy(player)
end

-- SECTION: Server Hop Loop (handled by hopSet)

-- SECTION: Reloader
task.spawn(function()
	while task.wait(10) do
		if getgenv().loaded then
			getgenv().loaded = false
			pcall(function() CoreGui.imgui:Destroy() end)
			loadstring(game:HttpGet("https://raw.githubusercontent.com/stacklua/Gru.lua/refs/heads/main/main"))()
		end
	end
end)
