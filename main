	while task.wait(10) do
		if getgenv().loaded then
			getgenv().loaded = false
			pcall(function() CoreGui.imgui:Destroy() end)
			loadstring(game:HttpGet("https://raw.githubusercontent.com/stacklua/Shrek.lua/refs/heads/main/main"))()
		end
	end
end)
