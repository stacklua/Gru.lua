-- SECTION: Booth Text
local function formatNumber(n)
	n = tonumber(n) or 0
	if n == 420 or n == 425 then n = n + 10 end
	if n >= 10000 then return string.format("%.1fk", n / 1000)
	elseif n >= 1000 then return string.format("%.2fk", n / 1000)
	else return tostring(n) end
end

local ALWAYS_GREEN = 2  -- pipes that are always green regardless of progress
local function buildProgressBar()
	local currentRaw = tonumber(newRaisedFormat.Value) or 0
	local goalDiff   = math.max(1, safeNum(getgenv().settings.goalDiff, 500))
	local raised     = math.max(0, currentRaw - raisedAtClaim)
	-- Reset cycle: once goal is hit, advance the baseline and start again
	if raised >= goalDiff then
		raisedAtClaim = raisedAtClaim + goalDiff
		raised = math.max(0, currentRaw - raisedAtClaim)
	end
	local totalPipes    = 5
	local progressGreen = math.floor(raised / goalDiff * (totalPipes - ALWAYS_GREEN))
	local green  = math.min(totalPipes, ALWAYS_GREEN + progressGreen)
	local black  = totalPipes - green
	local topText = safeStr(getgenv().settings.customBoothText)
	local goalStr = formatNumber(raisedAtClaim + goalDiff)
	local header  = topText ~= "" and (topText .. " | Goal " .. goalStr) or ("Goal " .. goalStr)
	return string.format(
		"<font color='rgb(30,144,255)' face='LuckiestGuy'>%s</font><br />" ..
		"<stroke thickness='6' color='rgb(0,0,0)'>" ..
		"<font size='17' face='GothamBlack'>" ..
		"<font color='rgb(0,255,0)'>%s</font>" ..
		"<font color='rgb(0,0,0)'>%s</font>" ..
		"</font></stroke>",
		header,
		string.rep("|", green),
		string.rep("|", black)
	)
end

function updateBoothText()
	local slot = unclaimed[1]
	if not slot then return end
	local currentRaw = tonumber(newRaisedFormat.Value) or 0
	local text = buildProgressBar()
	if #text > 250 then text = text:sub(1, 250) end
	local boothUI = _boothlocation.BoothUI:FindFirstChild("BoothUI" .. tostring(slot))
	if not boothUI then return end
	local signLabel = boothUI.Sign.TextLabel
	if signLabel.Text == text then return end
	if signLabel.Text:find("##") and nx >= 1 then setHopReason("Tagged booth") return serverHop() end
	local payload = {
		textFont          = Enum.Font.Arial,
		richText          = true,
		strokeColor       = Color3.new(0,0,0),
		strokeOpacity     = 0,
		textColor         = Color3.fromHex("#ffffff"),
		buttonStrokeColor = Color3.new(0,0,0),
		buttonTextColor   = Color3.new(1,1,1),
		buttonColor       = Color3.new(98,255,0),
		buttonHoverColor  = Color3.new(98,255,0),
		buttonLayout      = "",
		text              = text
	}
	Remotes.Event("SetCustomization"):FireServer(payload, "booth")
end

-- SECTION: Chat
local _TTSERVICE = cloneref(game:GetService('TextChatService'))
local _TCHANNEL  = _TTSERVICE.TextChannels.RBXGeneral
local function chat(msg)
	local ok = pcall(function() _TCHANNEL:SendAsync(tostring(msg or "")) end)
	if not ok then chatWorking = false end
end

-- SECTION: Begging Loop
local function begging()
	-- Always wait the full delay before the first message
	task.wait(safeNum(getgenv().settings.begDelay, 300))
	while getgenv().settings.autoBeg do
		local nearby = false
		local char = Players.LocalPlayer.Character
		if char and char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").RootPart then
			local root = char:FindFirstChildOfClass("Humanoid").RootPart
			for _, p in next, Players:GetPlayers() do
				if p ~= Players.LocalPlayer and p.Character
					and p.Character:FindFirstChildOfClass("Humanoid")
					and p.Character:FindFirstChildOfClass("Humanoid").RootPart then
					if (p.Character:FindFirstChildOfClass("Humanoid").RootPart.Position - root.Position).Magnitude < 15 then
						nearby = true; break
					end
				end
			end
		end
		if not nearby then
			local msgs = safeTable(getgenv().settings.begMessage)
			if #msgs > 0 then chat(msgs[math.random(#msgs)]) end
		end
		task.wait(safeNum(getgenv().settings.begDelay, 300))
	end
end

-- SECTION: Fetch Nearest Player
local function fetchNearPlr()
	local minmagnif, plrfoundf
	local lplrChar = Players.LocalPlayer.Character
	if lplrChar then
		local h = lplrChar:FindFirstChildOfClass('Humanoid')
		if h and h.RootPart then
			minmagnif = 9999999
			for i, v in next, Players:GetPlayers() do
				if v == Players.LocalPlayer then continue end
				if v.Character and v.Character:FindFirstChildOfClass('Humanoid') then
					local root = v.Character:FindFirstChildOfClass('Humanoid').RootPart
					if root then
						local dist = (root.Position - h.RootPart.Position).Magnitude
						if dist < minmagnif then minmagnif = dist; plrfoundf = v end
					end
				end
			end
		end
	end
	return plrfoundf
end

-- SECTION: Webhook
local function buildEmbed()
	return {
		title     = Players.LocalPlayer.Name .. " is farming donations",
		color     = 0xe8c355,
		thumbnail = { url = ("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=256&height=256&format=png"):format(uid) },
		fields    = {
			{ name = "⏱ Uptime", value = getUptime(), inline = true },
		},
		timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
		footer    = { text = "Gru.lua" }
	}
end

-- Returns the status channel URL — does NOT fall back to donation webhook
local function getStatusUrl()
	local s = safeStr(getgenv().settings.statusWebhookBox):match("%S+")
	if s and s ~= "" then return s end
	return nil
end

local function postStatusEmbed()
	local url = getStatusUrl()
	if not url or url == "" then return end
	local ok, res = pcall(function()
		return httprequest({ Url = url .. "?wait=true", Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = HttpService:JSONEncode({ embeds = { buildEmbed() } }) })
	end)
	if ok and res then pcall(function() embedMessageId = HttpService:JSONDecode(res.Body).id end) end
end

local function updateStatusEmbed()
	local url = getStatusUrl()
	if not url or url == "" or not embedMessageId then return end
	pcall(function()
		httprequest({ Url = url .. "/messages/" .. embedMessageId, Method = "PATCH", Headers = { ["Content-Type"] = "application/json" }, Body = HttpService:JSONEncode({ embeds = { buildEmbed() } }) })
	end)
end

local function webhook(raised, donor, donorId)
	local url = safeStr(getgenv().settings.webhookBox):match("%S+")
	if not url or url == "" then return end
	local embed = {
		title       = Players.LocalPlayer.Name .. " just got donated!",
		color       = 0xe8c355,
		description = string.format("**%d R$** donated by **%s**", raised, tostring(donor or "Unknown")),
		author      = donorId and { name = tostring(donor or ""), icon_url = ("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=256&height=256&format=png"):format(donorId) } or nil,
		thumbnail   = { url = ("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=256&height=256&format=png"):format(uid) },
		fields      = { { name = "⏱ Uptime", value = getUptime(), inline = true } },
		timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ")
	}
	pcall(function()
		httprequest({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = HttpService:JSONEncode({ embeds = { embed } }) })
	end)
	if getgenv().settings.pingEveryone and raised >= safeNum(getgenv().settings.pingAboveDono, 1000) then
		local pingTimes = raised >= 10000 and 100 or 1
		for _ = 1, pingTimes do
			pcall(function()
				httprequest({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = HttpService:JSONEncode({ content = "@everyone" }) })
			end)
		end
	end
end

-- SECTION: Anti-Bot & Blacklist
local flaggedTexts     = {'spin','jump','helicopter','+1 speed','gifting donations'}
local flaggedTextCount = 0
local function checkForBots()
	if not getgenv().settings.antiBotServers then return end
	local boothUiStuff = _boothlocation:WaitForChild("BoothUI", 5)
	if not boothUiStuff then return end
	for i, v in next, boothUiStuff:GetDescendants() do
		if v:IsA('TextLabel') then
			for _i, text in flaggedTexts do
				if string.find(v.Text:lower(), text) and not v:GetAttribute('flaggedtext') then
					flaggedTextCount += 1; v:SetAttribute('flaggedtext', true)
				end
			end
		end
	end
	if flaggedTextCount > 5 then serverHop() end
end

local function checkBlacklist(player)
	if not getgenv().settings.blacklistHop then return end
	local bl = safeTable(getgenv().settings.playerBlacklist)
	local name = (player.Name or ""):lower()
	for _, b in next, bl do
		if b == name then sessionHops += 1; setHopReason("Blacklisted: " .. player.Name); serverHop(); return end
	end
end

