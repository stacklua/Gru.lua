task.spawn(function()
	local pg = Players.LocalPlayer:WaitForChild("PlayerGui")
	local sg = Instance.new("ScreenGui")
	sg.Name = "ShrekHopTimer"
	sg.ResetOnSpawn = false
	sg.DisplayOrder = 200
	sg.IgnoreGuiInset = true
	sg.Parent = pg
	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.fromOffset(160, 26)
	lbl.Position = UDim2.new(1, -168, 0, 8)
	lbl.BackgroundColor3 = Color3.fromHex("#0e0e10")
	lbl.BackgroundTransparency = 0.2
	lbl.BorderSizePixel = 0
	lbl.TextColor3 = Color3.fromHex("#e8c355")
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = 12
	lbl.Text = "hop: waiting..."
	lbl.Parent = sg
	Instance.new("UICorner", lbl).CornerRadius = UDim.new(0, 6)
	while task.wait(1) do
		if nextHopTime then
			local remaining = math.max(0, nextHopTime - os.time())
			local m = math.floor(remaining / 60)
			local s = remaining % 60
			lbl.Text = string.format("hop in %dm %02ds", m, s)
		else
			lbl.Text = "hop: waiting..."
		end
	end
end)

