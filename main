-- SECTION: Helpers
local function safeStr(v)    return tostring(v or "") end
local function safeNum(v, d) return tonumber(v) or d or 0 end
local function safeTable(t)  return type(t) == "table" and t or {} end

local function splitLines(str)
	local result = {}
	for line in tostring(str or ""):gmatch("[^\n]+") do
		local s = line:match("^%s*(.-)%s*$")
		if s and s ~= "" then table.insert(result, s) end
	end
	return result
end

local function joinLines(t)
	local tbl = safeTable(t)
	return #tbl > 0 and table.concat(tbl, "\n") or ""
end

local function splitPipe(str)
	local result = {}
	for part in tostring(str or ""):gmatch("[^|]+") do
		local s = part:match("^%s*(.-)%s*$")
		if s and s ~= "" then table.insert(result, s) end
	end
	return result
end

local function joinPipe(t)
	local tbl = safeTable(t)
	return #tbl > 0 and table.concat(tbl, " | ") or ""
end

-- Comma split/join for reply fields (no spaces required, e.g. "hi,hello,hey")
local function splitCommaReplies(str)
	local result = {}
	for part in tostring(str or ""):gmatch("[^,]+") do
		local s = part:match("^%s*(.-)%s*$")
		if s and s ~= "" then table.insert(result, s) end
	end
	return result
end

local function joinCommaReplies(t)
	local tbl = safeTable(t)
	return table.concat(tbl, ",")
end

