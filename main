local resourcePreserverActive = false
local platformStandConn       = nil
local resourcePreserverDone   = false

local function activateResourcePreserver()
	if resourcePreserverDone then return end
	resourcePreserverDone = true
	repeat task.wait(0.5) until bclaimed
	task.wait(1)
	local charName = (Players.LocalPlayer.Character and Players.LocalPlayer.Character.Name) or ""
	local keep = { "BoothInteractions", "MapUI", "Camera", "Terrain", charName }
	local function shouldKeep(name)
		for _, k in ipairs(keep) do if name == k then return true end end
		return false
	end
	for _, obj in ipairs(workspace:GetChildren()) do
		if not shouldKeep(obj.Name) then pcall(function() obj:Destroy() end) end
	end
	local Lighting = game:GetService("Lighting")
	for _, obj in ipairs(Lighting:GetChildren()) do pcall(function() obj:Destroy() end) end
	pcall(function() workspace.Terrain:Clear() end)
	pcall(function()
		local char = Players.LocalPlayer.Character
		local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	end)
	local shrekBlackout = Instance.new("ScreenGui")
	shrekBlackout.Name           = "ShrekBlackout"
	shrekBlackout.DisplayOrder   = 50
	shrekBlackout.ResetOnSpawn   = false
	shrekBlackout.IgnoreGuiInset = true
	shrekBlackout.Parent         = CoreGui
	local bf = Instance.new("Frame")
	bf.Size             = UDim2.fromScale(1, 1)
	bf.BackgroundColor3 = Color3.new(0, 0, 0)
	bf.BorderSizePixel  = 0
	bf.Parent           = shrekBlackout
	for _, gui in ipairs(CoreGui:GetChildren()) do
		if gui:IsA("ScreenGui") and gui.Name ~= "ShrekBlackout" and gui.Name ~= "RobloxGui" then
			pcall(function() gui.DisplayOrder = 100 end)
		end
	end
	pcall(function() setfpscap(5) end)

end

local function deactivateResourcePreserver()
	resourcePreserverDone = false
	local existing = CoreGui:FindFirstChild("ShrekBlackout")
	if existing then pcall(function() existing:Destroy() end) end
	if platformStandConn then platformStandConn:Disconnect(); platformStandConn = nil end
end

Tabs.Resources:AddToggle("ResourcePreserver", {
	Title    = "Resource Preserver",
	Default  = getgenv().settings.resourcePreserver or false,
	Callback = function(v)
		resourcePreserverActive = v
		getgenv().settings.resourcePreserver = v; saveSettings()
		if v then task.spawn(activateResourcePreserver) else deactivateResourcePreserver() end
	end
})

Fluent:Notify({ Title = "Shrek.lua", Content = "Loaded", Duration = 3 })
settingsLock = false
Window:SelectTab(1)

if getgenv().settings.resourcePreserver then
	resourcePreserverActive = true
	task.spawn(activateResourcePreserver)
end

local function findUnclaimed()
	unclaimed = {}
	local boothUI      = _boothlocation:WaitForChild("BoothUI")
	local interactions = workspace:WaitForChild("BoothInteractions")
	local mainPos2D    = Vector3.new(mainCheckPosition.X, 0, mainCheckPosition.Z)
	for _, uiFrame in ipairs(boothUI:GetChildren()) do
		if uiFrame.Details.Owner.Text == "unclaimed" then
			local boothNum = tonumber(uiFrame.Name:match("%d+"))
			if boothNum then
				for _, interact in ipairs(interactions:GetChildren()) do
					if interact:GetAttribute("BoothSlot") == boothNum then
						local pos2D = Vector3.new(interact.Position.X, 0, interact.Position.Z)
						if (pos2D - mainPos2D).Magnitude < 92 then
							table.insert(unclaimed, boothNum); break
						end
					end
				end
			end
		end
	end
end

task.wait(3)
if not pcall(findUnclaimed) then serverHop() end
if #unclaimed == 0 then
	task.wait(3)
	pcall(findUnclaimed)
end
local claimCount = #unclaimed
if not unclaimed[1] then setHopReason("No booths available"); serverHop(); return end

getgenv().walkToBooth = function()
	local boothPos = boothCFrameForPosition(-6)
	if not boothPos then return end
	local hrp = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	pcall(function() workspace.Map.Decoration.Benches:Destroy() end)
	local dist = (hrp.Position - boothPos.Position).Magnitude
	local t = twn(hrp, TweenInfo.new(math.max(dist / 32, 0.2), Enum.EasingStyle.Linear), { CFrame = boothPos })
	t:Play()
	local tweenDone = false
	t.Completed:Connect(function() tweenDone = true end)
	task.spawn(function()
		while not tweenDone do
			task.wait(0.5)
			if unclaimed[1] then
				local boothFrame = _boothlocation.BoothUI:FindFirstChild("BoothUI" .. tostring(unclaimed[1]))
				if boothFrame and boothFrame.Details.Owner.Text ~= "unclaimed"
					and not string.find(boothFrame.Details.Owner.Text, Players.LocalPlayer.DisplayName) then
					t:Cancel()
					table.remove(unclaimed, 1)
					if unclaimed[1] then
						getgenv().walkToBooth()
					else
						serverHop()
					end
					return
				end
			end
		end
	end)
	t.Completed:Wait()
	hrp.CFrame = boothPos
	task.wait(0.6)
	bclaimed = true
end

walkToBooth()

local function boothclaim()
	Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[1])
	local boothFrame = _boothlocation.BoothUI:FindFirstChild("BoothUI" .. tostring(unclaimed[1]))
	if not boothFrame then error("no booth frame") end
	if not string.find(boothFrame.Details.Owner.Text, Players.LocalPlayer.DisplayName) then
		task.wait(1)
		if not string.find(boothFrame.Details.Owner.Text, Players.LocalPlayer.DisplayName) then
			error("not claimed")
		end
	end
end

while not pcall(boothclaim) do
	if errCount >= claimCount then setHopReason("All booths taken"); serverHop() end
	table.remove(unclaimed, 1); errCount += 1
end
hopSet()

