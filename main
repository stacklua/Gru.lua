-- ======================== RESOURCES ========================
local resourcePreserverActive = false
local platformStandConn       = nil

local function activateResourcePreserver()
	repeat task.wait(0.5) until bclaimed
	task.wait(1)

	-- Destroy everything in workspace except essentials
	local charName = (Players.LocalPlayer.Character and Players.LocalPlayer.Character.Name) or ""
	local keep = { "BoothInteractions", "MapUI", "Camera", "Terrain", charName }
	local function shouldKeep(name)
		for _, k in ipairs(keep) do if name == k then return true end end
		return false
	end
	for _, obj in ipairs(workspace:GetChildren()) do
		if not shouldKeep(obj.Name) then
			pcall(function() obj:Destroy() end)
		end
	end

	-- Clear sky, atmosphere, etc from Lighting
	local Lighting = game:GetService("Lighting")
	for _, obj in ipairs(Lighting:GetChildren()) do
		pcall(function() obj:Destroy() end)
	end

	-- Wipe terrain geometry
	pcall(function() workspace.Terrain:Clear() end)

	-- Create a baseplate under the character to stand on
	pcall(function()
		local char = Players.LocalPlayer.Character
		local hrp  = char and char:FindFirstChild("HumanoidRootPart")
		if hrp then
			local plate = Instance.new("Part")
			plate.Name        = "GruBaseplate"
			plate.Size        = Vector3.new(50, 1, 50)
			plate.Anchored    = true
			plate.CanCollide  = true
			plate.Material    = Enum.Material.SmoothPlastic
			plate.Color       = Color3.fromHex("#222222")
			plate.CFrame      = CFrame.new(hrp.Position.X, hrp.Position.Y - 3, hrp.Position.Z)
			plate.Parent      = workspace
		end
	end)

	-- Blackout: cover all Roblox UI, leave Gru.lua on top
	local gruBlackout = Instance.new("ScreenGui")
	gruBlackout.Name          = "GruBlackout"
	gruBlackout.DisplayOrder  = 50
	gruBlackout.ResetOnSpawn  = false
	gruBlackout.IgnoreGuiInset = true
	gruBlackout.Parent        = CoreGui
	local bf = Instance.new("Frame")
	bf.Size                   = UDim2.fromScale(1, 1)
	bf.BackgroundColor3       = Color3.new(0, 0, 0)
	bf.BorderSizePixel        = 0
	bf.Parent                 = gruBlackout
	for _, gui in ipairs(CoreGui:GetChildren()) do
		if gui:IsA("ScreenGui") and gui.Name ~= "GruBlackout" and gui.Name ~= "RobloxGui" then
			pcall(function() gui.DisplayOrder = 100 end)
		end
	end

	Fluent:Notify({ Title = "Resource Preserver", Content = "World cleared", Duration = 3 })
end

local function deactivateResourcePreserver()
	local existing = CoreGui:FindFirstChild("GruBlackout")
	if existing then pcall(function() existing:Destroy() end) end
	if platformStandConn then platformStandConn:Disconnect(); platformStandConn = nil end
end

Tabs.Resources:AddToggle("ResourcePreserver", {
	Title    = "Resource Preserver",
	Default  = false,
	Callback = function(v)
		resourcePreserverActive = v
		if v then task.spawn(activateResourcePreserver) else deactivateResourcePreserver() end
	end
})

Tabs.Resources:AddInput("FpsLimit", {
	Title    = "FPS Limit",
	Default  = tostring(safeNum(getgenv().settings.fpsLimit, 60)),
	Numeric  = true,
	Callback = function(v)
		if tonumber(v) and tonumber(v) >= 5 then
			getgenv().settings.fpsLimit = tonumber(v); saveSettings()
			if setfpscap then pcall(function() setfpscap(tonumber(v)) end) end
			if syn and syn.set_fps_cap then pcall(function() syn.set_fps_cap(tonumber(v)) end) end
		end
	end
})

