-- SECTION: Server Hop
local function choosePlaceId()
	if getgenv().settings.AlternativeHop and chatWorking then
		return (math.random() < 0.5) and 8943844393 or 8737602449
	end
	return 8737602449
end

local function serverHop()
	sessionHops = sessionHops + 1
	while task.wait(1.5) do
		if httprequest then
			task.spawn(function()
				local HS = game:GetService("HttpService")
				local TS = game:GetService("TeleportService")
				local P  = game:GetService("Players")
				local PlaceId = choosePlaceId()
				local ok, req = pcall(function()
					return httprequest({ Url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true", PlaceId) })
				end)
				if not ok then return end
				local ok2, body = pcall(function() return HS:JSONDecode(req.Body) end)
				if ok2 and body and body.data then
					-- Prune expired history entries
					local now = os.time()
					local pruned = {}
					for _, entry in ipairs(serverHistory) do
						if now - entry.time < SERVER_HISTORY_TTL then
							table.insert(pruned, entry)
						end
					end
					serverHistory = pruned
					-- Build set of recently visited job IDs
					local recentIds = {}
					for _, entry in ipairs(serverHistory) do recentIds[entry.jobId] = true end

					local servers = {}
					for _, s in pairs(body.data) do
						if s.playing < 25 and s.id ~= game.JobId and s.playing > 12
							and not recentIds[s.id] then
							table.insert(servers, s)
						end
					end
					-- Fall back to any valid server if all are in history
					if #servers == 0 then
						for _, s in pairs(body.data) do
							if s.playing < 25 and s.id ~= game.JobId and s.playing > 12 then
								table.insert(servers, s)
							end
						end
					end
					if #servers > 0 then
						local chosen = servers[math.random(1, #servers)]
						-- Record current server in history before leaving
						table.insert(serverHistory, { jobId = game.JobId, time = os.time() })
						getgenv().loadedRR = nil
						pcall(function() TS:TeleportToPlaceInstance(PlaceId, chosen.id, P.LocalPlayer) end)
					end
				end
			end)
		end
	end
end

local HOP_INTERVAL = 4 * 60   -- always 4 minutes
local nextHopTime  = nil

local function hopSet()
	if hopTimer then task.cancel(hopTimer) end
	nextHopTime = os.time() + HOP_INTERVAL
	hopTimer = task.spawn(function()
		while task.wait(1) do
			if os.time() >= nextHopTime then
				setHopReason("Timer")
				serverHop()
				return
			end
		end
	end)
end

local function extendHopTimer()
	if nextHopTime then
		nextHopTime = nextHopTime + 60  -- push back 1 minute on donation
	end
end

local function twn(...) return TweenService:Create(...) end

-- SECTION: Uptime
local function getUptime()
	local e = os.time() - sessionStart
	local m = math.floor(e / 60)
	return string.format("%d min", m)
end

-- SECTION: Emote Helpers
local function stopEmote()
	if emoteTrack then
		pcall(function() emoteTrack:Stop() end)
		emoteTrack = nil
	end
end

local function playEmote()
	local id = safeStr(getgenv().settings.emoteId)
	-- Note: Roblox engine fires a sanitization warn internally — this is cosmetic only, animation still plays
	if id == "" or id == "0" then return end
	local char = Players.LocalPlayer.Character
	if not char then return end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	stopEmote()
	local ok, objects = pcall(function() return game:GetObjects("rbxassetid://" .. id) end)
	if not ok or not objects then return end
	for _, obj in ipairs(objects) do
		local animAsset = obj:IsA("Animation") and obj or obj:FindFirstChildOfClass("Animation", true)
		if animAsset then
			local ok2, track = pcall(function() return humanoid:LoadAnimation(animAsset) end)
			if ok2 and track then
				emoteTrack = track
				emoteTrack.Looped = true
				emoteTrack:Play()
				pcall(function() obj:Destroy() end)
				return
			end
		end
		pcall(function() obj:Destroy() end)
	end
end

-- SECTION: Booth Helpers
local function getBoothInteract()
	for _, v in ipairs(workspace.BoothInteractions:GetChildren()) do
		if v:GetAttribute("BoothSlot") == unclaimed[1] then return v end
	end
	return nil
end

local function boothCFrameForPosition(posValue)
	local theCframe
	if string.find(tostring(posValue), "6") then
		theCframe = CFrame.new(posValue, 0, 0)
	else
		theCframe = CFrame.new(0, 0, posValue)
	end
	local interact = getBoothInteract()
	if not interact then return nil end
	return interact.CFrame * theCframe
end

local function facingBoothFront(playerPos)
	local fountainPos = nil
	pcall(function()
		fountainPos = workspace.Map.Decoration.Middle.WaterFountain.WaterPart.Position
	end)
	if not fountainPos then
		pcall(function()
			local wf = workspace:FindFirstChild("WaterFountain", true)
			if wf then fountainPos = wf.Position end
		end)
	end
	if fountainPos then
		local flatTarget = Vector3.new(fountainPos.X, playerPos.Y, fountainPos.Z)
		return CFrame.new(playerPos, flatTarget)
	end
	local interact = getBoothInteract()
	if not interact then return CFrame.new(playerPos) end
	local look = interact.CFrame.LookVector
	local flatLook = Vector3.new(look.X, 0, look.Z).Unit
	return CFrame.new(playerPos, playerPos + flatLook)
end

local function moveToBoothSpot(posValue)
	local boothPos = boothCFrameForPosition(posValue)
	if not boothPos then return end
	local hrp = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local dist = (hrp.Position - boothPos.Position).Magnitude
	local t = twn(hrp, TweenInfo.new(math.max(dist / 32, 0.2), Enum.EasingStyle.Linear), { CFrame = boothPos })
	t:Play()
	t.Completed:Connect(function()
		hrp.CFrame = facingBoothFront(hrp.Position)
	end)
end

